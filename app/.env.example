# Copy to .env and fill in real values. .env is gitignored and
# dockerignored; only .env.example is meant to be committed.
# Loaded into the container automatically via `--env-file app/.env`.

# OAuth client from Google Cloud Console (Web application type, with
# http://localhost:8080/oauth2callback added as an authorized redirect
# URI), used to authorize access to the dedicated Gmail account. Run
# `make auth` once after setting these to obtain and store a refresh
# token. The consent screen stays in Testing mode (gmail.modify/gmail.send
# are restricted/sensitive scopes -- getting out of Testing needs a paid
# third-party security audit), so Google expires that token after 7 days;
# poll.mjs emails a reminder at day 6.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# The dedicated Gmail address this agent reads and sends from.
GMAIL_USER_EMAIL=

# Your own email -- where operational notices (currently just the reauth
# reminder above) get sent. Deliberately separate from GMAIL_USER_EMAIL:
# nobody reads the dedicated agent account's own inbox, so a reminder sent
# there would go unseen. Required for the reminder to be useful at all.
OPERATOR_EMAIL=

# Comma-separated list of sender addresses allowed to trigger the agent.
# Fails closed: if this is unset or empty, no inbound mail is processed at
# all, from anyone -- including the dedicated account itself, which is
# always excluded regardless of this list (loop prevention).
ALLOWED_SENDERS=

# Persona name used in replies and when registering for accounts.
PERSONA_NAME=Baxter Burgundy

# Model for the per-email claude -p runs. sonnet (default) balances cost
# against the agentic browsing/scripting Baxter does; haiku is cheaper/faster
# but riskier on multi-step tasks; opus is the most capable/expensive.
BAXTER_MODEL=sonnet

# Which agent harness runs each message: "claude" (Claude Code, the default),
# "openrouter" (via OpenRouter's Agent SDK), or "local" (any OpenAI-compatible
# chat/completions endpoint -- a self-hosted model, OpenAI, etc.). Unset/empty
# defaults to claude. Any OTHER value crashes the daemon at startup (fail-fast on
# a typo, rather than silently dropping every message).
#BAXTER_HARNESS=claude

# OpenRouter harness (only used when BAXTER_HARNESS=openrouter). Runs Baxter via
# OpenRouter's Agent SDK against the model you pick, reusing the same skills/CLIs.
#OPENROUTER_API_KEY=sk-or-...
#OPENROUTER_MODEL=openai/gpt-4o     # must support tool calling
#OPENROUTER_MAX_STEPS=40            # optional: caps the tool-loop iterations per run
#OPENROUTER_MAX_TOKENS=0            # optional context guard: stop the run once cumulative
                                    #   token usage exceeds this (0 = off). The SDK owns the
                                    #   message array so we can't trim it, only halt early. It
                                    #   sums BILLED tokens across steps (each step re-bills the
                                    #   whole history), so cumulative usage crosses N well before
                                    #   the live context does -- set this to a few MULTIPLES of
                                    #   your model's window, not the window itself.
#OPENROUTER_CONTEXT_RETRY_MAX=2     # if the model's window IS exceeded, truncate the oldest
                                    #   tool outputs in the saved state and resume, up to N times,
                                    #   before ending the run gracefully.
#OPENROUTER_MULTIMODAL_MODEL=minimax/minimax-m3   # optional: when a Discord post carries media
                                    #   (image/video/audio/PDF), route THAT run to this multimodal
                                    #   model with the attachment(s) attached to the prompt; other
                                    #   runs use OPENROUTER_MODEL. Empty/unset = feature off.
#OPENROUTER_MEDIA_AUDIO_MAX_BYTES=8388608   # optional: audio is sent as base64 (no URL passthrough),
                                    #   so cap it -- attachments over this are skipped (default 8 MiB).

# Local / OpenAI-compatible harness (only used when BAXTER_HARNESS=local). Drives
# any OpenAI chat/completions endpoint -- a local model via Ollama (default),
# LM Studio, llama.cpp, vLLM, or a hosted one. The model MUST support tool calling.
#OPENAI_BASE_URL=http://localhost:11434/v1   # default; Ollama's OpenAI-compatible API
#OPENAI_MODEL=qwen3                           # e.g. an Ollama model tag / OpenAI model id
#OPENAI_API_KEY=                              # optional -- most local servers ignore it
#OPENAI_MAX_STEPS=40                          # optional: caps tool-loop iterations per run
#OPENAI_CONTEXT_MAX_TOKENS=24000              # context guard: before each call, stub the oldest
                                              #   tool results in place to keep history under this
                                              #   (~chars/4). Set to ~your model's context window
                                              #   (num_ctx); lower for small local models, 0 = off.
#OPENAI_CONTEXT_RETRY_MAX=2                    # if the window is still exceeded, trim the history
                                              #   harder (halving it) and retry N times, then stop
                                              #   gracefully.

# How often poll.mjs checks Gmail for new mail.
POLL_INTERVAL_SECONDS=60

# Operational safety caps, not permission guardrails -- keep a bad prompt
# or a broken thread from spiraling into a flood of emails.
MAX_EMAILS_PER_CYCLE=5
MAX_SENDS_PER_DAY=500

# --- Discord bot (optional; unset DISCORD_BOT_TOKEN disables it entirely) ---
# Bot token from the Discord Developer Portal (Bot tab). The Message Content
# privileged intent MUST be enabled there. The daemon writes it to a 0600 file
# at startup and STRIPS it from the spawned run's env, and discord-cli reads it
# from that file -- so the per-message claude run never carries the token in its
# environment (mirrors how gmail.mjs reads gmail-token.json).
# Invite the bot with every permission EXCEPT: Create Invite, Kick/Ban Members,
# Manage Roles, Manage Channels, Manage Server, Administrator, Moderate Members.
DISCORD_BOT_TOKEN=
# Daily Discord send cap (flood guard), analogous to MAX_SENDS_PER_DAY.
DISCORD_MAX_SENDS_PER_DAY=2500
# Recent scrollback fed to each run's prompt. Kept small -- most triggers only
# need recent context and the run can pull more via `discord-cli fetch-history`.
# Bump it for busy channels; Discord returns <=100 per request (values >100 are
# clamped, no pagination). Must be >= 1 -- 0 is rejected at startup.
DISCORD_HISTORY_LIMIT=25
# Max media attachments from a trigger post forwarded to the multimodal model
# (only when OPENROUTER_MULTIMODAL_MODEL is set). Also caps the coalesce carry-forward.
DISCORD_MEDIA_MAX_ATTACHMENTS=4
# Per-channel coalescing window (ms): rapid messages become one run.
DISCORD_DEBOUNCE_MS=4000
# Global cap on simultaneous claude runs across channels.
DISCORD_MAX_CONCURRENT_RUNS=5
# Per-channel hourly run budget -- the hard terminator for a bot-to-bot loop
# (which runs serially, so the concurrency caps above never bound it). Once a
# channel hits this many runs in an hour, further triggers there are dropped
# until the window rolls off. 0 = unlimited (falls back to the daily send cap).
DISCORD_MAX_RUNS_PER_CHANNEL_PER_HOUR=150
# Optional comma-separated guild-id allowlist. Empty = any invited server.
DISCORD_GUILD_ALLOWLIST=

# --- Voice ("Fast Baxter", opt-in; `make voice`) ---
# The voice bot (scripts/voice-bot.mjs) auto-joins ONE voice channel whenever a
# human is in it and speaks via Piper TTS. It self-disables unless this is set to
# a voice channel id, AND the GuildVoiceStates intent is enabled in the Developer
# Portal (non-privileged -- just tick it). Experimental; not in the default fleet.
# DISCORD_VOICE_CHANNEL_ID=
# What he says when he joins (phase 1). Later phases add listening + dispatch.
# VOICE_GREETING=Hey, Fast Baxter here. What's up?
# Which Piper voice. Baked into the image: en_US-lessac-medium (default, neutral),
# en_US-amy-medium (US female), en_US-ryan-medium (US male). Any other name is
# ignored (falls back to the default) unless you also bake it in the Dockerfile.
# VOICE_NAME=en_US-lessac-medium
# Speaking pace (Piper --length_scale): >1 slower, <1 faster; empty = model default.
# VOICE_LENGTH_SCALE=1.0
# Safety cap on characters synthesized per utterance (later phases feed model text).
# VOICE_MAX_SPEECH_CHARS=600
# Ears (phase 2): transcribe what people say via whisper.cpp. On by default when the
# voice bot runs; VOICE_LISTEN=0 = greeting-only (phase 1). VOICE_SILENCE_MS is the
# end-of-utterance gap (ms) that closes a speaker's audio and triggers transcription.
# VOICE_LISTEN=1
# VOICE_SILENCE_MS=800
# Hard cap on one capture (ms): force-ends a never-silent source (music bot / stuck mic).
# VOICE_MAX_UTTERANCE_MS=60000
# Fast brain (phase 3): a single OpenRouter call decides answer-aloud vs dispatch to
# the full agent. Needs OPENROUTER_API_KEY (above); no key = ears-only (transcribe +
# log, no responses). Model defaults to OPENROUTER_MODEL. Context = rolling turns kept.
# VOICE_BRAIN_MODEL=minimax/minimax-m2.7
# VOICE_BRAIN_CONTEXT_TURNS=8

# --- Code execution sandbox (codapi) ---
# Where the app reaches the codapi service (see `make codapi`). The default
# works on the shared docker network; override only if you relocate the service.
# CODAPI_URL=http://codapi:1313
# The enforced per-run limits (offline, memory, pids, timeout) live in
# app/codapi/codapi.json -- edit there and re-run `make codapi` to change them
# (they're baked into the codapi server image, not read from this file).

# --- Heartbeat scheduler (make heartbeat) ---
# Driver tick interval (how often it scans for due tasks).
HEARTBEAT_INTERVAL_SECONDS=60
# Invisibility window: a claimed task won't be re-fired for this long (protects
# a slow/crashed run from double-firing).
HEARTBEAT_VISIBILITY_MINUTES=15
# Failed fires retried after the window; after this many the fire gives up (a
# one-shot is dropped; a cron reschedules to its next occurrence, attempts reset).
HEARTBEAT_MAX_ATTEMPTS=3
# Enforced guardrails (fail closed on a bad value): min gap between a recurring
# task's fires; max tasks in the schedule; max total fires per UTC day.
HEARTBEAT_MIN_INTERVAL_MINUTES=60
HEARTBEAT_MAX_TASKS=100
HEARTBEAT_MAX_FIRES_PER_DAY=200
# Fallback timezone for a task with no --tz (Baxter usually sets the requester's).
# Also the timezone the openrouter/local runners show the model as the current
# local time (see BAXTER_TZ to override just that).
HEARTBEAT_TZ=America/Los_Angeles
# Timezone shown as "now" in the openrouter/local system preamble (every run gets
# the current date/time injected, since these harnesses -- unlike Claude Code --
# don't otherwise tell the model the date). Defaults to HEARTBEAT_TZ, then Pacific.
#BAXTER_TZ=America/Los_Angeles
