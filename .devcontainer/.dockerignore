# Build context is this .devcontainer/ dir (see `make build-dev`), and the
# Dockerfile COPYs nothing, so only entries that can appear here matter -- chiefly
# keeping a local .env out of the build context. (The old repo-root rules for
# node_modules/.venv/etc. were dead here and were dropped.)
.env
.env.*
!.env.example
.DS_Store
